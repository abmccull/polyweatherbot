# Polymarket credentials (POLY_PROXY / email login)
POLY_PRIVATE_KEY=0x...your_private_key...
POLY_FUNDER_ADDRESS=0x...your_proxy_wallet_address...
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
# Optional explicit builder credentials for relayer redemptions.
# If omitted, bot falls back to POLY_API_* values above.
# NOTE: Builder key alone is insufficient for relayer auth; use the matching
# key + secret + passphrase from the same Builder credential set.
BUILDER_API_KEY=
BUILDER_API_SECRET=
BUILDER_API_PASSPHRASE=
RELAYER_URL=https://relayer-v2.polymarket.com
CLOB_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
CLOB_USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user

# Synoptic Data API (optional, free tier)
SYNOPTIC_API_TOKEN=

# Database
DB_PATH=station_sniper.db

# Trading
INITIAL_BANKROLL=200.0
DRY_RUN=true
ENABLE_MARKET_WS=true
ENABLE_USER_WS=true
WS_RECONNECT_SECONDS=5
WS_PING_INTERVAL=20
MARKET_PRICE_MAX_AGE=5
ORDERBOOK_404_COOLDOWN_SECONDS=900

# Proxy-wallet redemption automation (no MATIC needed in relayer mode)
REDEEM_PROXY_VIA_RELAYER=true
REDEEM_RELAYER_GAS_LIMIT=1500000
REDEEM_RELAYER_MAX_POLLS=30
REDEEM_RELAYER_POLL_MS=2000
REDEEM_RELAYER_MAX_SUBMITS_PER_CYCLE=3
REDEEM_RELAYER_SUBMIT_SPACING_SECONDS=1.25
REDEEM_RELAYER_429_BACKOFF_INITIAL_SECONDS=120
REDEEM_RELAYER_429_BACKOFF_MAX_SECONDS=1800
REDEMPTION_INTERVAL=3600
REDEMPTION_QUIET_HOURS_ENABLED=true
REDEMPTION_QUIET_TIMEZONE=America/Denver
REDEMPTION_QUIET_START_HOUR=23
REDEMPTION_QUIET_END_HOUR=6

# Copy only fresh wallet trades (seconds)
COPY_TRADE_MAX_AGE_SECONDS=300
COPY_MAX_NEW_TRADES_PER_POLL=25
COPY_CORE_POLL_PRIORITY=true
COPY_SKIP_INACTIVE_EVENTS=true
COPY_SETTLE_GRACE_SECONDS=120
COPY_MIN_LEADER_PRICE=0.05
COPY_MAX_LEADER_PRICE=0.95
COPY_PROBATION_MAX_OPEN_RISK_SHARE=0.60
COPY_PROBATION_MAX_OPEN_LOCKS=8
COPY_PROBATION_MIN_SECONDS_BETWEEN_ENTRIES=20
COPY_MIN_CASH_BUFFER_USD=20

# Shadow expansion mode (more opportunities, smaller/safer bets)
SHADOW_EXPANSION_ENABLED=false
SHADOW_MIN_CONFIDENCE=0.78
SHADOW_MIN_PRICE=0.20
SHADOW_MAX_PRICE=0.75
SHADOW_METAR_MAX_AGE_MINUTES=45
SHADOW_GEQ_MIN_HOUR=9
SHADOW_LEQ_MIN_HOUR=15
SHADOW_MAX_BET_USD=25
SHADOW_MAX_BANKROLL_PCT=0.03
SHADOW_MIN_EXPECTED_EDGE=0.03
SHADOW_MIN_EXPECTED_PROFIT=0.25
SHADOW_EXACT_ENABLED=false
SHADOW_EXACT_MIN_HOUR=15
SHADOW_EXACT_MIN_CONFIDENCE=0.90
SHADOW_EXACT_MAX_BET_USD=10

# Adaptive time gate relaxation
ADAPTIVE_TIME_GATES_ENABLED=true
ADAPTIVE_TIME_GATE_NO_EMIT_CYCLES=90
ADAPTIVE_TIME_GATE_STEP_HOURS=1
ADAPTIVE_TIME_GATE_MIN_GEQ_HOUR=8
ADAPTIVE_TIME_GATE_MIN_LEQ_HOUR=14
ADAPTIVE_TIME_GATE_RESET_ON_EMIT=true

# Liquidity quality gate
LIQUIDITY_GATE_ENABLED=true
LIQUIDITY_MIN_ASK_DEPTH_USD=40
LIQUIDITY_MAX_SPREAD_ABS=0.08
LIQUIDITY_MAX_SPREAD_PCT_OF_ASK=0.22

# Passive entry logic
PASSIVE_ENTRY_ENABLED=true
PASSIVE_ENTRY_MIN_SPREAD_ABS=0.02
PASSIVE_ENTRY_JOIN_TICKS=1
PASSIVE_ENTRY_TICK_SIZE=0.01

# Signal KPI watchdog
SIGNAL_KPI_ENABLED=true
SIGNAL_KPI_WINDOW_HOURS=6
SIGNAL_KPI_MIN_CANDIDATES=200
SIGNAL_KPI_MIN_EMITTED=1
SIGNAL_KPI_MAX_TIME_GATE_RATIO=0.65
SIGNAL_KPI_MAX_EXACT_RATIO=0.65
SIGNAL_KPI_AUTO_SHADOW_EXPAND=true
SIGNAL_KPI_AUTO_EXACT_PILOT=true
SIGNAL_KPI_AUTO_ADAPTIVE_GATES=true

# Dynamic sizing + adaptive aggression
DYNAMIC_MAX_BET_ENABLED=true
DYNAMIC_MAX_BET_PCT=0.08
DYNAMIC_MAX_BET_FLOOR=150
DYNAMIC_MAX_BET_CAP=5000
AGGRESSION_ENABLED=true
AGGRESSION_MIN_SAMPLES=40
AGGRESSION_TARGET_WIN_RATE=0.90
AGGRESSION_CONFIDENCE_Z=1.64
AGGRESSION_MAX_BOOST=0.75
AGGRESSION_DRAWDOWN_GUARD=0.12

# Self-learning
SELF_LEARNING_ENABLED=true
SELF_LEARNING_LOOKBACK_DAYS=180
SELF_LEARNING_MIN_SAMPLES=30
SELF_LEARNING_MIN_SEGMENT_SAMPLES=5
SELF_LEARNING_PRIOR_ALPHA=2.0
SELF_LEARNING_PRIOR_BETA=2.0
SELF_LEARNING_CITY_PRIOR=30
SELF_LEARNING_HOUR_PRIOR=20
SELF_LEARNING_BUCKET_PRIOR=16
SELF_LEARNING_PRECISION_PRIOR=24
SELF_LEARNING_BLEND=0.55
SELF_LEARNING_RELIABILITY_SAMPLES=80
SELF_LEARNING_CONFIDENCE_SCALE=0.30
SELF_LEARNING_CONFIDENCE_CAP=0.08

# Post-cost EV gate
ENABLE_EV_GATE=true
MIN_EXPECTED_EDGE=0.02
MIN_EXPECTED_PROFIT=0.50
EV_BASE_SLIPPAGE_BPS=20
EV_DEPTH_SLIPPAGE_MAX=0.02
EV_SPREAD_WEIGHT=0.50
EV_DYNAMIC_SLIPPAGE=true

# Exit/risk controls
HARD_STOP_LOSS_ENABLED=true
HARD_STOP_LOSS_PCT=0.65
